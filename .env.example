# Application
FISHRAG_APP_NAME=FishRag
FISHRAG_ENV=local
FISHRAG_LOG_LEVEL=INFO
FISHRAG_API_PREFIX=/api/v1
FISHRAG_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FISHRAG_JWT_SECRET_KEY=change-me-in-local-env
FISHRAG_JWT_ISSUER=fishrag
FISHRAG_ACCESS_TOKEN_EXPIRE_MINUTES=120

# Storage
FISHRAG_STORAGE_DIR=storage
FISHRAG_UPLOAD_DIR=storage/uploads
FISHRAG_MAX_UPLOAD_BYTES=52428800

# PostgreSQL / pgvector
POSTGRES_IMAGE=pgvector/pgvector:pg16-bookworm
FISHRAG_DATABASE_URL=postgresql+asyncpg://fishrag:fishrag@localhost:5432/fishrag
POSTGRES_DB=fishrag
POSTGRES_USER=fishrag
POSTGRES_PASSWORD=fishrag
POSTGRES_PORT=5432

# Redis
REDIS_IMAGE=redis:7-alpine
FISHRAG_REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# OpenSearch
OPENSEARCH_IMAGE=opensearchproject/opensearch:2.15.0
FISHRAG_OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_PORT=9200
OPENSEARCH_DISABLE_SECURITY=true

# Model providers
# Default cloud chat provider: DeepSeek
# Get an API key from DeepSeek, then replace the `sk-...` placeholder below.
FISHRAG_LLM_PROVIDER=deepseek
FISHRAG_LLM_BASE_URL=https://api.deepseek.com
FISHRAG_LLM_API_KEY=sk-replace-with-your-deepseek-api-key
FISHRAG_CHAT_MODEL=deepseek-v4-flash
FISHRAG_LLM_THINKING=disabled

# DeepSeek handles chat. SiliconFlow handles embedding and reranking.
FISHRAG_EMBEDDING_PROVIDER=siliconflow
FISHRAG_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
FISHRAG_EMBEDDING_API_KEY=sk-replace-with-your-siliconflow-api-key
FISHRAG_EMBEDDING_MODEL=BAAI/bge-m3

FISHRAG_RERANKER_PROVIDER=siliconflow
FISHRAG_RERANKER_BASE_URL=https://api.siliconflow.cn/v1
FISHRAG_RERANKER_API_KEY=sk-replace-with-your-siliconflow-api-key
FISHRAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
